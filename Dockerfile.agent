FROM golang:1.26 AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=arm64 go build -o /agent ./cmd/agent

# headless-shell: stripped headless Chromium maintained by the chromedp project
FROM chromedp/headless-shell:stable
ENV CHROME_PATH=/headless-shell/headless-shell
# headless-shell ships no CA bundle; without it every AWS TLS call fails x509 verification.
COPY --from=build /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/ca-certificates.crt
COPY --from=build /agent /agent
ENTRYPOINT ["/agent"]
